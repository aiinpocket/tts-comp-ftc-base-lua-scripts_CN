}

function showPhaseGuide(phaseName)
    local guide = phaseGuide[phaseName]
    if guide then
        Global.UI.setAttribute("phaseInfoPanel", "active", "true")
        Global.UI.setValue("phaseTitle", guide.title)
        Global.UI.setValue("phaseBody", guide.body)
    end
end
-- === END CN Phase Guide ===

-- === CN Pregame Guide (CA 2025 賽前流程) ===
pregameSteps = {
    title = "CA 2025 賽前準備流程（錦標賽序列）",
    body = "[1] 召集軍隊 — 確認雙方軍隊名單合法（積分、陣營）\n"..
           "\n"..
           "[2] 決定任務 — 從任務池抽取主要任務與部署地圖\n"..
           "    （TTS中：使用左側任務選擇器）\n"..
           "\n"..
           "[3] 閱讀任務 — 確認主要任務得分方式與特殊規則\n"..
           "\n"..
           "[4] 放置目標標記 — 按部署卡指示擺放目標\n"..
           "    （TTS中：點選部署圖後自動生成）\n"..
           "\n"..
           "[5] 決定攻守方 — 雙方擲骰，贏家選擇桌邊\n"..
           "    D6 對決：高者為攻方，選擇桌邊\n"..
           "\n"..
           "[6] 選擇次要任務 — 秘密選擇固定或戰術模式\n"..
           "    固定：選2張固定次要任務，整場有效\n"..
           "    戰術：每指揮階段抽2張（首回合）\n"..
           "    ★ 雙方鎖定後點擊 Lock Secondaries ★\n"..
           "\n"..
           "[7] 宣告戰鬥編制 — 秘密決定：\n"..
           "    • 領袖附屬到哪個護衛單位\n"..
           "    • 哪些單位搭乘運輸載具\n"..
           "    • 哪些單位放入預備隊/戰略預備隊\n"..
           "    預備隊限制：不超過總兵力一半（積分與單位數）\n"..
           "    然後同時公開所有決定\n"..
           "\n"..
           "[8] 部署軍隊\n"..
           "    雙方交替將單位從手中放到桌面，防守方先放\n"..
           "    每次放置一個單位，須完全在己方部署區內\n"..
           "    泰坦(Titanic)單位放置時，對手跳過該次\n"..
           "    一方全部放完後，另一方依序放完剩餘單位\n"..
           "\n"..
           "[9] 重新部署\n"..
           "    雙方都擺完後，部分單位擁有「重新部署」能力\n"..
           "    可將已部署的單位移到己方部署區內其他位置\n"..
           "    攻方先執行 → 防守方後執行\n"..
           "    若雙方都沒有此能力則跳過此步驟\n"..
           "\n"..
           "[10] 決定先攻 — 雙方擲骰 D6 對決\n"..
           "     贏家決定先攻或後攻\n"..
           "     （TTS中：用下方 Toggle First Player 按鈕）\n"..
           "\n"..
           "[11] 解決戰前規則\n"..
           "     所有標註「戰鬥開始前」觸發的能力在此執行\n"..
           "     最常見：偵察移動 Scouts X\"\n"..
           "       • 擁有 Scouts 關鍵字的單位可移動最多 X\"\n"..
           "       • 先攻方先移動 → 後攻方後移動\n"..
           "       • 結束時不可在敵方模型 9\" 範圍內\n"..
           "       • 若無任何戰前能力則跳過此步驟\n"..
           "\n"..
           "[12] 開始戰鬥！ — 點擊 START GAME"
}

function showPregameGuide()
    Global.UI.setAttribute("pregamePanel", "active", "true")
    Global.UI.setValue("pregameTitle", pregameSteps.title)
    Global.UI.setValue("pregameBody", pregameSteps.body)
end

function closePregamePanel()
    Global.UI.setAttribute("pregamePanel", "active", "false")
end

function hidePregameGuide()
    Global.UI.setAttribute("pregamePanel", "active", "false")
end
