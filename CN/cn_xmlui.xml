<!-- Xml UI. See documentation: https://api.tabletopsimulator.com/ui/introUI/ -->
<Defaults>
<Button width="550" height="300" fontSize="40" onClick="" fontStyle="Bold"/>
<Text fontSize="100" color="#000000" fontStyle="Bold"/>
</Defaults>

<Panel id="redirect" active="false" position="0 0 0" scale="0.6 0.6 0.6" offsetXY="0 0" color="#dbeaf9" width="1200" height="800" rectAlignment="MiddleCenter">
<Text offsetXY="0 350" fontSize="80" color="#E74C3C" fontStyle="Bold">警告</Text>

<Text id="coreRedirect" offsetXY="0 0" fontSize="40" color="#ECF0F1">
請等待載入中
</Text>

<Button id="closeRedirectBtn" active="true" offsetXY="0 -400" color="#1A1A1A" textColor="#FFFFFF" width="500" height="100" fontSize="40" fontStyle="Bold" onClick="closeRedir" outline="#E74C3C" outlineSize="5" roundEdges="true">關閉</Button>
</Panel>

<Panel id="main" active="false" position="0 0 0" scale="0.5 0.5 0.5" offsetXY="0 0" color="#dbeaf9" outline="#34495E" outlineSize="8" width="1600" height="1000" rectAlignment="MiddleCenter" visibility="Diamonds">
<Text offsetXY="0 400" fontSize="70" color="#2C3E50" fontStyle="Bold">選擇你的座位</Text>

<Button id="redBtn" offsetXY="-400 150" color="#DA1917" textColor="#FFFFFF" width="500" height="150" fontSize="45" roundEdges="true" onClick="placeToRed">紅方玩家</Button>
<Button id="blueBtn" offsetXY="400 150" color="#1E87FF" textColor="#FFFFFF" width="500" height="150" fontSize="45" roundEdges="true" onClick="placeToBlue">藍方玩家</Button>

<Text fontSize="50" color="#E74C3C" offsetXY="0 -50" fontStyle="Bold">使用其他玩家顏色風險自負！</Text>

<Button id="greyBtn" offsetXY="0 -200" color="#BDC3C7" textColor="#2C3E50" width="1000" height="150" fontSize="45" roundEdges="true" onClick="placeToGray">旁觀者</Button>

<Button id="closeBtn" offsetXY="0 -500" color="#2C3E50" textColor="#FFFFFF" width="500" height="100" fontSize="40" fontStyle="Bold" onClick="closeMenu" outline="#34495E" outlineSize="5" roundEdges="true">關閉選單</Button>
</Panel>

<Panel id="trackingConsentPopup" active="false" position="0 0 0" scale="0.5 0.5 0.5" offsetXY="0 0" color="#dbeaf9" outline="#34495E" outlineSize="8" width="1600" height="1000" rectAlignment="MiddleCenter" visibility="Black">
<Text id="trackingConsentTitle" offsetXY="0 315" fontSize="54" color="#2C3E50" fontStyle="Bold">解鎖遊戲統計與對局功能</Text>
<Button id="trackingConsentAllowBtn" offsetXY="-320 95" color="#4CAF50" textColor="#FFFFFF" width="500" height="132" fontSize="34" roundEdges="true" onClick="allowTrackingConsent">儲存我的個人檔案</Button>
<Button id="trackingConsentDeclineBtn" offsetXY="320 95" color="#E57373" textColor="#FFFFFF" width="500" height="132" fontSize="33" roundEdges="true" onClick="declineTrackingConsent">保持隱私</Button>

<Text offsetXY="-320 -25" fontSize="30" color="#44576B" fontStyle="Bold">若您同意</Text>
<Text offsetXY="-350 -145" fontSize="20" color="#5D6D7E" alignment="UpperCenter" width="660" height="175">
• 在 stats.hutber.com 獲得個人表現頁面
• https://stats.hutber.com/tts/userprofile
• 查看賽後詳情與表現分析
• Steam ID 和顯示名稱會被儲存，但預設不公開
• 可選擇是否公開個人檔案
• 同意選項與隱私政策版本
</Text>

<Text offsetXY="320 -25" fontSize="30" color="#44576B" fontStyle="Bold">若您保持隱私</Text>
<Text offsetXY="350 -145" fontSize="20" color="#5D6D7E" alignment="UpperCenter" width="660" height="175">
• 你的對局將不會被儲存
• 不會產生表現頁面
• 你可以隨時啟用此功能
• 個人資料不會被儲存於 stats.hutber.com
</Text>

<Button id="trackingConsentCloseBtn" offsetXY="0 -300" color="#2C3E50" textColor="#FFFFFF" width="440" height="86" fontSize="34" fontStyle="Bold" onClick="closeTrackingConsentPopup" outline="#34495E" outlineSize="5" roundEdges="true">關閉</Button>
</Panel>

<Panel id="passTurn" active="true" position="525 495 0" scale="0.5 0.5 0.5" offsetXY="40 0" color="#00000000" visibility="Black">
<Button id="passTurnBtn" offsetXY="0 0" color="#C0392B" textColor="#FFFFFF" width="200" height="180" fontSize="40" fontStyle="Bold" roundEdges="true" onClick="nextPhase"></Button>
<Text id="passTurnTxt" offsetXY="0 0" color="#FFFFFF" width="180" height="180" fontSize="35" fontStyle="Bold" onClick="nextPhase">下一階段</Text>
</Panel>

<Panel id="Chess Stopwatch" active="false" scale="1 1 1" width="180" height="120" rectAlignment="UpperRight" offsetXY="-270 0" allowDragging="true" restrictDraggingToParentBounds="false" returnToOriginalPositionWhenReleased="false">
<VerticalLayout spacing="5" padding="5">
<Panel id="ChsStpPanel1" color="Blue">
<Button id="ChsStpBtn1" scale="1 1 1" width="180" height="60" onClick="" color="rgba(0,0,0,0)"/>
<Text id="ChsStpWatch1" text="0:00:00" fontSize="40" color="White"/>
</Panel>
<Panel id="ChsStpPanel2" color="Red">
<Button id="ChsStpBtn2" scale="1 1 1" width="180" height="60" onClick="" color="rgba(0,0,0,0)"/>
<Text id="ChsStpWatch2" text="0:00:00" fontSize="40" color="White"/>
</Panel>
</VerticalLayout>
</Panel>

<Panel id="feedbackPopup" active="false" width="400" height="420" rectAlignment="MiddleCenter" allowDragging="false" color="#000000EE">
<VerticalLayout spacing="5" padding="10">
<VerticalLayout spacing="5" padding="10" childControlHeight="false" childForceExpandHeight="false">
<InputField id="feedbackName" placeholder="名稱" onValueChanged="onNameChanged" />
<InputField id="feedbackEmail" value="jamie@hutber.com" placeholder="電子郵件" onValueChanged="onEmailChanged" />
<Dropdown id="feedbackType" onValueChanged="onTypeChanged">
<Option value="">類型</Option>
<Option value="bug">錯誤回報</Option>
<Option value="feature">功能建議</Option>
<Option value="other">其他</Option>
<Option value="single">你單身嗎？</Option>
</Dropdown>
<InputField id="feedbackMessage" placeholder="訊息" lineType="MultiLineNewline" height="150" onValueChanged="onMessageChanged" />
<Dropdown id="feedbackLike" onValueChanged="onLikeChanged">
<Option value="">你討厭致命面孔嗎？</Option>
<Option value="loveit">其實還不錯（我喜歡）</Option>
<Option value="Yes">是</Option>
<Option value="No">否</Option>
<Option value="I fucking HATE IT">我超級討厭</Option>
<Option value="You bastard">我不喜歡你</Option>
</Dropdown>
</VerticalLayout>
<HorizontalLayout spacing="2" height="40">
<Button id="feedbackSubmitBtn" text="送出" onClick="" width="120" height="40"/>
<Button id="feedbackCloseBtn" text="關閉" onClick="" width="120" height="40"/>
</HorizontalLayout>
</VerticalLayout>
</Panel>

<Panel id="phaseInfoPanel" active="false" position="0 460 0" scale="0.7 0.7 0.7" color="#1A1A1ADD" width="1100" height="450" rectAlignment="UpperCenter" allowDragging="true" restrictDraggingToParentBounds="false" returnToOriginalPositionWhenReleased="false">
<Text id="phaseTitle" offsetXY="0 185" fontSize="42" color="#FFD700" fontStyle="Bold" alignment="UpperCenter">指揮階段</Text>
<Text id="phaseBody" offsetXY="0 -15" fontSize="26" color="#ECECECEE" alignment="UpperCenter" width="1050" height="380">階段說明載入中...</Text>
</Panel>


<Panel id="loadingPanel" active="false" position="0 0 0" scale="0.6 0.6 0.6" color="#0D0D0DEE" width="800" height="300" rectAlignment="MiddleCenter">
<Text id="loadingTitle" offsetXY="0 80" fontSize="48" color="#FFD700" fontStyle="Bold" alignment="MiddleCenter">Loading...</Text>
<Text id="loadingBody" offsetXY="0 -30" fontSize="28" color="#ECECECEE" alignment="MiddleCenter" width="750" height="120">正在載入任務包與卡牌資源，請稍候...</Text>
</Panel>

<Panel id="pregamePanel" active="false" position="0 0 0" scale="0.62 0.62 0.62" color="#0D0D0DEE" width="1300" height="1100" rectAlignment="MiddleCenter" allowDragging="true" restrictDraggingToParentBounds="false" returnToOriginalPositionWhenReleased="false">
<Text id="pregameTitle" offsetXY="0 505" fontSize="44" color="#FFD700" fontStyle="Bold" alignment="UpperCenter">CA 2025 賽前準備流程</Text>
<Text id="pregameBody" offsetXY="0 -20" fontSize="28" color="#ECECECEE" alignment="UpperCenter" width="1240" height="980">載入中...</Text>
<Button id="pregameCloseBtn" offsetXY="600 505" color="#FFFFFF22" textColor="#AAAAAA" width="120" height="50" fontSize="28" onClick="closePregamePanel">✕</Button>
</Panel>

<Panel id="tutorialPanel" active="false" position="-520 280 0" scale="0.5 0.5 0.5" color="#1A1A1AEE" width="750" height="720" rectAlignment="MiddleCenter" allowDragging="true" restrictDraggingToParentBounds="false" returnToOriginalPositionWhenReleased="false" outline="#FFD700" outlineSize="3">
